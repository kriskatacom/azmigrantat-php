RewriteEngine On
RewriteBase /

# 1. Защита: Ако някой се опита да достъпи директно папка public, го спираме (опционално)
# RewriteRule ^public/(.*)$ /$1 [L,NC,R=301]

# 2. Assets: Гарантираме, че заявките за активи винаги сочат към правилната папка, 
# без значение дали в URL има /bg/ или /en/
RewriteRule ^(bg|en)/assets/(.*)$ public/assets/$2 [L,NC]
RewriteRule ^assets/(.*)$ public/assets/$1 [L,NC]

# 3. Автоматично пренасочване от началната страница към /bg/ (ако няма език)
RewriteRule ^$ /bg/ [L,R=301]

# 4. Основно рутиране
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]
